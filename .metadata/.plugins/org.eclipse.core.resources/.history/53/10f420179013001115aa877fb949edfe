package com.prac.product_category_two_entity_case_study.service;

import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.web.bind.annotation.RequestBody;

import com.prac.product_category_two_entity_case_study.dto.Category;
import com.prac.product_category_two_entity_case_study.repo.CategoryRepository;

@Service
public class CategoryService {

	@Autowired
	private CategoryRepository category;
	
	
	public Category savecategory(@RequestBody Category c) {

		if(category.existsByName(c.getName())) {
			throw new RuntimeException("Name already exist");
		}else {
			return category.save(c);
		}
	}
	
	public List<Category> getAllCategory(){
		return category.findAll();
	}
	
	public Category getCategoryById()
}
