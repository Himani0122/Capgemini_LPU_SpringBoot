package com.prac.product_category_two_entity_case_study.dto;

import java.util.List;

import com.prac.product_category_two_entity_case_study.Product;

import jakarta.persistence.Entity;
import jakarta.persistence.Id;
import jakarta.persistence.OneToMany;

@Entity
public class Category {
	@Id
	private int cid;
	private String name;
	private String discription;
	
	@OneToMany(mappedBy = "category")
	private List<Product> products;
	
	Category(){
		
	}
	

	public int getCid() {
		return cid;
	}

	public void setCid(int cid) {
		this.cid = cid;
	}

	public String getName() {
		return name;
	}

	public void setName(String name) {
		this.name = name;
	}

	public String getDiscription() {
		return discription;
	}

	public void setDiscription(String discription) {
		this.discription = discription;
	}

	public Category(int cid, String name, String discription) {
		super();
		this.cid = cid;
		this.name = name;
		this.discription = discription;
	}

	@Override
	public String toString() {
		return "Category [cid=" + cid + ", name=" + name + ", discription=" + discription + "]";
	}
	
}
