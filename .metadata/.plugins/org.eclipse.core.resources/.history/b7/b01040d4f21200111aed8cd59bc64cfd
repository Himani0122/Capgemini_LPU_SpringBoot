	//how to enter list elements
	@PostMapping("/person")
	public String getperson(@RequestBody Person p) {
		System.out.println(p);
		return p.toString();
	}
	
	@PostMapping("/college")
	public String getcollege(@RequestBody College c) {
		System.out.println(c);
		return c.toString();
